{
  "name": "poker-trainer",
  "version": "1.0.0",
  "description": "Poker training platform — unified single-service deployment",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install-all": "npm install --prefix server && npm install --prefix client",
    "build": "npm run build --prefix client",
    "start": "node server/index.js",
    "dev:server": "node server/index.js",
    "dev:client": "npm run dev --prefix client",
    "test": "npx jest && npm test --prefix client",
    "test:server": "npm test --prefix server",
    "test:client": "npm test --prefix client",
    "test:e2e": "npx playwright test",
    "test:e2e:setup": "npx playwright test --project=auth-setup",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "simulate": "node simulate_game.js",
    "batches": "node simulate_batches.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "xlsx": "^0.18.5"
  }
}
