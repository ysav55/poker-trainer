# ─────────────────────────────────────────────────────────────────────────────
# Poker Trainer — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Authentication (REQUIRED) ────────────────────────────────────────────────

# Strong random secret used to sign JWT session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server WILL NOT START without this value.
SESSION_SECRET=replace-with-a-long-random-string


# ── Supabase (REQUIRED) ──────────────────────────────────────────────────────

# Found in: Supabase dashboard → Project Settings → API

# Your project's public REST endpoint
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — NEVER expose this to the browser.
# Used server-side only for DB writes and admin operations.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Anon/public key — safe for client-side requests.
# Currently stubbed in browser (all client reads go via Express + JWT).
# Still needed by server/db/supabase.js if you switch to anon queries.
SUPABASE_ANON_KEY=eyJ...your-anon-key

# Direct PostgreSQL connection — used ONLY by scripts/run-migration.js.
# Found in: Supabase dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres


# ── Network (recommended for production) ─────────────────────────────────────

# Allowed CORS origin for the Express API and Socket.io.
# Set to your frontend domain to restrict cross-origin access.
# If left empty in production a warning is printed but requests still work
# from same-origin (the React build is served by the same Express process).
# Example:  CORS_ORIGIN=https://poker.yourclub.com
CORS_ORIGIN=

# Port the server listens on (default: 3001)
PORT=3001

# Set to "production" for prod deployments (enables CORS warning, etc.)
NODE_ENV=development


# ── Vite (client build-time — prefix required for Vite to expose to browser) ─
# These are only needed if you re-enable direct Supabase calls from the browser.
# Currently the client uses server-proxied API calls and these are unused.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key
